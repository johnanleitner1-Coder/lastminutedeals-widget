# ── LMDH shared infra ──────────────────────────────────────────────
# SQLite (persistent volume on Railway)
DATABASE_PATH=/data/widget.db

# OpenAI (GPT-4.1-mini)
OPENAI_API_KEY=sk-proj-...

# Widget
WIDGET_BASE_URL=https://widget.lastminutedealshq.com
CORS_ORIGINS=https://oturista.pt,https://www.oturista.pt

# Dashboard
DASHBOARD_HMAC_SECRET=a-random-secret-string

# Stripe Connect — LMDH platform key (all Stripe API calls go through this)
STRIPE_PLATFORM_SECRET_KEY=sk_test_lmdh_platform_key

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=a-random-verify-string
WHATSAPP_APP_SECRET=

# ── Per-operator credentials ──────────────────────────────────────
# O Turista Tours (Eduardo)
BOKUN_API_KEY_OTURISTA=eduardo_bokun_octo_api_key
STRIPE_WEBHOOK_SECRET_OTURISTA=whsec_eduardo_webhook_secret
# stripe_connect_account_id is set in config.py after onboarding (e.g. acct_1NXyz...)
